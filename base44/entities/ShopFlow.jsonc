{
  "name": "ShopFlow",
  "type": "object",
  "properties": {
    "name": {
      "type": "string",
      "description": "Flow name"
    },
    "color": {
      "type": "string",
      "default": "blue",
      "description": "Preset color key"
    },
    "sequence": {
      "type": "string",
      "description": "JSON array of zone IDs in flow order",
      "default": "[]"
    }
  },
  "required": [
    "name"
  ]
}